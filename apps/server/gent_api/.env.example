# Environment Configuration Template
# Copy this file to .env and fill in your actual values

# Environment
DJANGO_ENV=development

# Security
# Generate a new SECRET_KEY with: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=your-secret-key-here
DEBUG=True

# Database
# For SQLite (development): sqlite:///db.sqlite3
# For PostgreSQL: postgresql://user:password@localhost:5432/dbname
DATABASE_URL=sqlite:///db.sqlite3

# CORS Configuration
# In development, you can use True. In production, set to False and configure CORS_ALLOWED_ORIGINS
CORS_ALLOW_ALL_ORIGINS=True

# Sentry Error Tracking
# Get your DSN from https://sentry.io/ after creating a project
# Leave empty to disable Sentry integration
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
# Sampling rates: 1.0 = 100%, 0.1 = 10%, etc.
SENTRY_TRACES_SAMPLE_RATE=1.0
SENTRY_PROFILES_SAMPLE_RATE=1.0

# Monitoring
PROMETHEUS_METRICS_ENABLED=True

# OpenTelemetry (Grafana LGTM Integration)
# Enable/disable OpenTelemetry instrumentation
OTEL_ENABLED=True
# Service name that appears in traces and metrics
OTEL_SERVICE_NAME=gent-api
# OTLP endpoint for Grafana LGTM (HTTP protocol)
# The LGTM container exposes OTLP on port 4318 (HTTP) and 4317 (gRPC)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
